{
    "compilerOptions": {
        "jsx": "react",
        "target": "ES2015",
        "module": "commonjs",
        "strict": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "baseUrl": "src/",
        "paths": {
            "@h/*": [
                "src/hooks/*"
            ],
            "@c/*": [
                "src/components/*"
            ]
        }
    },
    "$schema": "https://json.schemastore.org/tsconfig",
    "display": "Recommended"
}